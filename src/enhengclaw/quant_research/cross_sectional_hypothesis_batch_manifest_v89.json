        "factor_formula": "family_X = mean(z(X_5d), z(X_20d), z(X_60d)) for X in {rv, iv, dh, tt}; raw = -0.30*family_rv -0.25*family_iv +0.25*family_dh -0.20*family_tt; final = tanh((percentile_rank(raw)-0.5)*1.80)",
