    "ENHENGCLAW_MARKET_OBSERVER_MODEL_NAME",
    "ENHENGCLAW_MARKET_OBSERVER_API_KEY",
    "ENHENGCLAW_MARKET_OBSERVER_MODEL_TIMEOUT_SECONDS"
