    "blocked",
    "quarantine",
    "failed"
  ],
  "resume_only": true,
  "live_backend_env": [
    "ENHENGCLAW_RISK_SIGNAL_AGENT_MODEL_BASE_URL",
    "ENHENGCLAW_RISK_SIGNAL_AGENT_MODEL_NAME",
    "ENHENGCLAW_RISK_SIGNAL_AGENT_API_KEY",
    "ENHENGCLAW_RISK_SIGNAL_AGENT_MODEL_TIMEOUT_SECONDS"
  ]
}
