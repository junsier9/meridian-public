{
  "contract_version": "openclaw-risk-signal-agent.v1",
  "entrypoint_module": "enhengclaw.integrations.openclaw.risk_signal_agent",
  "lane_id": "risk_signal_agent",
  "request_fields": [
    "contract_version",
    "subject",
    "scope",
    "object_id",
    "risk_text",
    "execution_permit_path"
  ],
  "optional_request_fields": [
