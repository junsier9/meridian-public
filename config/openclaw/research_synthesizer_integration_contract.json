{
  "contract_version": "openclaw-research-synthesizer.v1",
  "entrypoint_module": "enhengclaw.integrations.openclaw.research_synthesizer",
  "lane_id": "research_synthesizer",
  "request_fields": [
    "contract_version",
    "subject",
    "scope",
    "object_id",
    "synthesis_text",
    "execution_permit_path"
  ],
  "optional_request_fields": [
    "input_id",
    "artifacts_root",
    "compiler_backend",
    "recorded_transcript_path"
  ],
  "recorded_replay_required_fields": [
    "input_id",
    "recorded_transcript_path"
  ],
  "response_statuses": [
    "success",
    "blocked",
    "quarantine",
    "failed"
  ],
  "resume_only": true,
  "live_backend_env": [
    "ENHENGCLAW_RESEARCH_SYNTHESIZER_MODEL_BASE_URL",
    "ENHENGCLAW_RESEARCH_SYNTHESIZER_MODEL_NAME",
    "ENHENGCLAW_RESEARCH_SYNTHESIZER_API_KEY",
    "ENHENGCLAW_RESEARCH_SYNTHESIZER_MODEL_TIMEOUT_SECONDS"
  ]
}
