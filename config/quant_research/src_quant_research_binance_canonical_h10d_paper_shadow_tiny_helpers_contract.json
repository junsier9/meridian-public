        "expected": {
          "price": 12.5,
          "bad": 0.0,
          "missing": 0.0,
          "none_row": 0.0
        }
      }
    },
    "_paper_shadow_action": {
      "signature": {
        "parameters": [
          {
            "annotation": "float",
            "default_repr": null,
            "kind": "KEYWORD_ONLY",
            "name": "previous_weight",
            "required": true
          },
          {
            "annotation": "float",
            "default_repr": null,
            "kind": "KEYWORD_ONLY",
            "name": "target_weight",
            "required": true
          }
        ],
        "return_annotation": "str"
      },
      "action_samples": [
        {
          "previous_weight": 0.0,
          "target_weight": 0.5,
          "expected": "open_long"
        },
        {
          "previous_weight": 0.5,
          "target_weight": 0.0,
          "expected": "close_long"
        },
        {
          "previous_weight": -0.5,
          "target_weight": 0.5,
          "expected": "flip_to_long"
        },
        {
          "previous_weight": 0.25,
          "target_weight": 0.5,
          "expected": "increase_long"
        },
        {
          "previous_weight": -0.75,
          "target_weight": -0.25,
          "expected": "reduce_short"
        }
      ]
    }
  },
