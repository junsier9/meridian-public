  "facade_module": "enhengclaw.quant_research.binance_canonical_h10d",
  "facade_path": "src/enhengclaw/quant_research/binance_canonical_h10d.py",
  "scope": "Freeze only internal archive-helper importability, root-facade re-export identity, constant identity, inspect.signature shape, and tiny behavior samples for low-coupling kline archive helpers. This contract intentionally excludes _partition_month, funding loaders, PIT universe behavior, full archive schemas, and full validation behavior.",
  "validation_mode": "internal_module_facade_signature_tiny_archive_samples",
  "approved_by_dry_run": "docs/quant_research/00_roadmap_state/src_quant_research_binance_canonical_h10d_archive_helper_slice_dry_run_2026_05_15.md",
  "implementation_plans": [
    "docs/quant_research/00_roadmap_state/src_quant_research_binance_canonical_h10d_read_kline_path_implementation_plan_2026_05_15.md",
    "docs/quant_research/00_roadmap_state/src_quant_research_binance_canonical_h10d_coerce_kline_frame_implementation_plan_2026_05_15.md",
    "docs/quant_research/00_roadmap_state/src_quant_research_binance_canonical_h10d_symbol_to_subject_implementation_plan_2026_05_15.md",
    "docs/quant_research/00_roadmap_state/src_quant_research_binance_canonical_h10d_symbol_audit_summary_implementation_plan_2026_05_15.md"
  ],
  "constant_targets": {
    "KLINE_FLOAT_COLUMNS": [
      "open",
      "high",
      "low",
      "close",
      "volume",
      "quote_volume",
      "taker_buy_base_volume",
      "taker_buy_quote_volume"
    ],
    "KLINE_INT_COLUMNS": [
      "open_time_ms",
      "close_time_ms",
      "trade_count"
    ]
  },
  "archive_helper_targets": {
    "_read_kline_path": {
      "signature": {
        "parameters": [
          {
            "annotation": "Path",
            "default_repr": null,
            "kind": "POSITIONAL_OR_KEYWORD",
            "name": "path",
            "required": true
          }
        ],
        "return_annotation": "pd.DataFrame"
      },
      "csv_gz_sample": {
        "file_name": "sample.csv.gz",
        "csv_text": "open_time_ms,open,close\n1000,1.5,1.7\n2000,2.5,2.7\n",
        "expected_records": [
          {
            "open_time_ms": 1000,
            "open": 1.5,
            "close": 1.7
          },
          {
            "open_time_ms": 2000,
            "open": 2.5,
            "close": 2.7
          }
        ]
      },
      "unsupported_file_name": "sample.txt",
      "unsupported_error_substring": "unsupported Binance archive partition format"
    },
    "_coerce_kline_frame": {
      "signature": {
        "parameters": [
          {
            "annotation": "pd.DataFrame",
            "default_repr": null,
            "kind": "POSITIONAL_OR_KEYWORD",
            "name": "frame",
            "required": true
          }
        ],
        "return_annotation": "None"
      },
      "coerce_sample": {
        "records": [
          {
            "open_time_ms": "1000",
            "close_time_ms": "1999",
            "trade_count": "7",
            "open": "1.5",
            "quote_volume": "20.25",
            "unchanged": "x"
          },
          {
            "open_time_ms": "bad",
            "close_time_ms": "bad",
            "trade_count": "bad",
            "open": "bad",
            "quote_volume": "bad",
            "unchanged": "y"
          }
        ],
        "expected_numeric_values": {
          "open_time_ms": [
            1000.0,
            null
          ],
          "close_time_ms": [
            1999.0,
            null
          ],
          "trade_count": [
            7.0,
            null
          ],
          "open": [
            1.5,
            null
          ],
          "quote_volume": [
            20.25,
            null
          ]
        },
        "expected_unchanged_values": [
          "x",
          "y"
        ]
      }
    },
    "symbol_to_subject": {
      "signature": {
        "parameters": [
          {
            "annotation": "str",
            "default_repr": null,
            "kind": "POSITIONAL_OR_KEYWORD",
            "name": "symbol",
            "required": true
          }
        ],
        "return_annotation": "str"
      },
      "sample_cases": {
        "lowercase_usdt": {
          "symbol": "btcusdt",
          "expected_subject": "BTC"
        },
        "trimmed_usdt": {
          "symbol": " ethusdt ",
          "expected_subject": "ETH"
        },
        "non_usdt": {
          "symbol": "SOLBUSD",
          "expected_subject": "SOLBUSD"
        }
      }
    },
    "_summarize_symbol_audits": {
      "signature": {
        "parameters": [
          {
            "annotation": "list[dict[str, Any]]",
            "default_repr": null,
            "kind": "POSITIONAL_OR_KEYWORD",
            "name": "symbol_audits",
            "required": true
          }
        ],
        "return_annotation": "dict[str, Any]"
      },
      "summary_sample": {
        "symbol_audits": [
          {
            "status": "ok",
            "invalid_daily_bucket_count": 1,
            "invalid_4h_bucket_count": 0,
            "invalid_1h_bucket_count": 2
          },
          {
            "status": "missing",
            "invalid_daily_bucket_count": 3,
            "invalid_4h_bucket_count": 4,
            "invalid_1h_bucket_count": 0
          }
        ],
        "expected_summary": {
          "symbol_count": 2,
          "ok_symbol_count": 1,
          "missing_or_empty_symbol_count": 1,
          "invalid_daily_bucket_count": 4,
          "invalid_4h_bucket_count": 4,
          "invalid_1h_bucket_count": 2
        }
      }
    }
  },
  "deferred_targets": [
    "_partition_month",
    "_symbol_partition_paths",
    "aggregate_1m_klines",
    "build_symbol_feature_frame",
    "build_binance_canonical_dataset",
    "funding loaders",
    "PIT universe helpers"
  ],
  "excluded_surfaces": [
    "source migration",
    "_partition_month archive/funding boundary",
    "funding sync behavior",
    "funding load behavior",
    "PIT universe behavior",
    "full archive schemas",
    "parquet engine behavior",
    "archive partition discovery",
    "aggregate_1m_klines behavior",
    "build_symbol_feature_frame behavior",
    "build_binance_canonical_dataset behavior",
    "gap-audit field expansion",
    "validation metrics",
    "strategy promotion status",
    "live-readiness authorization",
    "caller counts"
  ]
}
