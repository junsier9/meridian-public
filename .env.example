# Required provider credentials for real shadow ingestion.
BINANCE_API_KEY=replace_me
ALCHEMY_API_KEY=replace_me

# Optional live CEX override used by replay/live pilot demos.
REAL_CEX_API_KEY=
REAL_CEX_API_BASE_URL=https://api.binance.com
REAL_CEX_TIMEOUT=5

# Optional CoinAPI market-data sidecar for quant research history sync.
# Keep using the local environment variable name `CoinAPI`; do not commit real keys.
CoinAPI=

# Optional Coinglass derivatives sidecar for quant research history sync.
# Keep using the local environment variable name `CoinglassAPI`; do not commit real keys.
CoinglassAPI=

# Optional OKX private API token. Not required for the current public funding-history sync.
OKX_API=

# Optional execution/runtime overrides.
ENHENGCLAW_EXECUTION_PERMIT_PATH=
ENHENGCLAW_TRUST_ROOT_DIR=
ENHENGCLAW_LEASE_REGISTRY_PATH=
ENHENGCLAW_RUNTIME_SESSION_ROOT=
ENHENGCLAW_OPERATIONAL_AUDIT_ROOT=

# Shared OpenClaw live baseline for the operator-facing deployment bundle.
# `OPENCLAW` remains the shared API key; the fields below act as default baseline values
# when per-lane `ENHENGCLAW_<LANE>_*` overrides are absent.
OPENCLAW=
OPENCLAW_BASE_URL=https://api.openai.com/v1
OPENCLAW_MODEL_NAME=gpt-5.4
OPENCLAW_MODEL_TIMEOUT_SECONDS=30

# market_observer live compiler backend.
# Public market_observer CLI defaults to live and fails closed when these are missing.
ENHENGCLAW_MARKET_OBSERVER_MODEL_BASE_URL=
ENHENGCLAW_MARKET_OBSERVER_MODEL_NAME=
ENHENGCLAW_MARKET_OBSERVER_API_KEY=
ENHENGCLAW_MARKET_OBSERVER_MODEL_TIMEOUT_SECONDS=30

# evidence_agent live compiler backend.
# Public evidence_agent CLI defaults to live and fails closed when these are missing.
ENHENGCLAW_EVIDENCE_AGENT_MODEL_BASE_URL=
ENHENGCLAW_EVIDENCE_AGENT_MODEL_NAME=
ENHENGCLAW_EVIDENCE_AGENT_API_KEY=
ENHENGCLAW_EVIDENCE_AGENT_MODEL_TIMEOUT_SECONDS=30

# Pending raw-input execution slices.
# Public CLI defaults to live for each slice, but public governed writes remain blocked until promotion.
ENHENGCLAW_RISK_SIGNAL_AGENT_MODEL_BASE_URL=
ENHENGCLAW_RISK_SIGNAL_AGENT_MODEL_NAME=
ENHENGCLAW_RISK_SIGNAL_AGENT_API_KEY=
ENHENGCLAW_RISK_SIGNAL_AGENT_MODEL_TIMEOUT_SECONDS=30

ENHENGCLAW_RISK_GOVERNANCE_AGENT_MODEL_BASE_URL=
ENHENGCLAW_RISK_GOVERNANCE_AGENT_MODEL_NAME=
ENHENGCLAW_RISK_GOVERNANCE_AGENT_API_KEY=
ENHENGCLAW_RISK_GOVERNANCE_AGENT_MODEL_TIMEOUT_SECONDS=30

ENHENGCLAW_VALIDATION_AGENT_MODEL_BASE_URL=
ENHENGCLAW_VALIDATION_AGENT_MODEL_NAME=
ENHENGCLAW_VALIDATION_AGENT_API_KEY=
ENHENGCLAW_VALIDATION_AGENT_MODEL_TIMEOUT_SECONDS=30

ENHENGCLAW_ATTENTION_ALLOCATOR_MODEL_BASE_URL=
ENHENGCLAW_ATTENTION_ALLOCATOR_MODEL_NAME=
ENHENGCLAW_ATTENTION_ALLOCATOR_API_KEY=
ENHENGCLAW_ATTENTION_ALLOCATOR_MODEL_TIMEOUT_SECONDS=30

ENHENGCLAW_RESEARCH_SYNTHESIZER_MODEL_BASE_URL=
ENHENGCLAW_RESEARCH_SYNTHESIZER_MODEL_NAME=
ENHENGCLAW_RESEARCH_SYNTHESIZER_API_KEY=
ENHENGCLAW_RESEARCH_SYNTHESIZER_MODEL_TIMEOUT_SECONDS=30

ENHENGCLAW_RESEARCH_LEAD_MODEL_BASE_URL=
ENHENGCLAW_RESEARCH_LEAD_MODEL_NAME=
ENHENGCLAW_RESEARCH_LEAD_API_KEY=
ENHENGCLAW_RESEARCH_LEAD_MODEL_TIMEOUT_SECONDS=30

# Optional direct OpenAI key used by one-off quant research LLM scoring scripts.
OPENAI_API_KEY=

# Optional provider-neutral Ethereum RPC URL for M3.2 backfill via `eth_getLogs`.
ETH_RPC_URL=

# Reserved M3.2 on-chain aggregate provider token.
# `Crypto_Quant_API` matches the existing local naming convention.
Crypto_Quant_API=

# Optional uppercase alias for future tooling that prefers explicit provider naming.
CRYPTOQUANT_API_KEY=

# M3.1 Tardis.dev options-chain dataset probe.
# Keep using the owner-provided local environment variable name `Tardis_api_key`.
Tardis_api_key=

# Optional TronScan auth. Current aggregate USDT_TRX sync works against public endpoints without these.
TRONSCAN_API_KEY=
TRON_PRO_API_KEY=

# deterministic and recorded compiler backends remain explicit fallback/testing modes only.

# Optional short-soak override used by readiness scripts.
ENHENGCLAW_SHORT_SOAK_DURATION_SECONDS=300
